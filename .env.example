# Required: Prisma/PostgreSQL connection strings.
# For local setup, these are often the same URL.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# Optional: enables AWS Bedrock-backed intake and eligibility analysis.
# Use a short-term Bedrock API key. If unset, the app tries to generate one from
# your AWS session credentials; if that also fails, it uses local fallback analysis.
AWS_BEARER_TOKEN_BEDROCK="short-term-bedrock-api-key"
AWS_REGION="us-east-1"
BEDROCK_MODEL_ID="amazon.nova-lite-v1:0"
